{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "position": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "mis"] },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "academicYears": {
      "title": "Academic Year",
      "description": "Educational year records",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "date": { "type": "string" }
      },
      "required": ["id", "date"]
    },
    "semesters": {
      "title": "Semester",
      "description": "School terms/semesters",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "half": { "type": "string" }
      },
      "required": ["id", "half"]
    },
    "institutionUsers": {
      "title": "Institution User",
      "description": "Records of all students, teachers, and MIS",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "lastName": { "type": "string" },
        "firstName": { "type": "string" },
        "middleName": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["Student", "Teacher", "MIS"] }
      },
      "required": ["id", "lastName", "firstName", "email", "role"]
    },
    "sections": {
      "title": "Section",
      "description": "Class sections",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "classes": {
      "title": "Class",
      "description": "Class assignments linking years, semesters, and teachers",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "academicYearId": { "type": "number" },
        "semesterId": { "type": "number" },
        "sectionId": { "type": "number" },
        "userId": { "type": "number" }
      },
      "required": ["id", "academicYearId", "semesterId", "sectionId", "userId"]
    },
    "classUsers": {
      "title": "Class User",
      "description": "Links students to specific classes",
      "type": "object",
      "properties": {
        "classId": { "type": "number" },
        "userId": { "type": "number" }
      },
      "required": ["classId", "userId"]
    },
    "studyPlans": {
      "title": "Study Plan",
      "description": "Generated study plan for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planText": { "type": "string" },
        "syllabusName": { "type": "string" },
        "calendarName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "planText"]
    },
    "resources": {
      "title": "Resource",
      "description": "Educational resources like syllabus or calendar files",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "string" },
        "date": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["Modules", "Course Outline", "Videos"] },
        "ownerId": { "type": "string" },
        "section": { "type": "string" }
      },
      "required": ["name", "type", "content", "category", "size", "ownerId", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile data"
    },
    "/users/{userId}/studyPlans/{planId}": {
      "schema": "studyPlans",
      "description": "User's study plans"
    },
    "/academicYears/{yearId}": {
      "schema": "academicYears",
      "description": "Academic year records"
    },
    "/semesters/{semesterId}": {
      "schema": "semesters",
      "description": "Semester records"
    },
    "/institutionUsers/{userId}": {
      "schema": "institutionUsers",
      "description": "Institutional user records"
    },
    "/sections/{sectionId}": {
      "schema": "sections",
      "description": "Class sections"
    },
    "/classes/{classId}": {
      "schema": "classes",
      "description": "Class assignments"
    },
    "/classUsers/{linkId}": {
      "schema": "classUsers",
      "description": "Student class assignments"
    },
    "/resources/{resourceId}": {
      "schema": "resources",
      "description": "Educational resource files"
    }
  }
}
