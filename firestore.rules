rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMIS() {
      return isAuthenticated() &&
        (getUserData().role == 'mis' ||
          (request.auth.token.email.lower() == "mistest373@gmail.com") ||
          (request.auth.token.email.lower() == "dianegrace.0103@gmail.com"));
    }

    function isTeacher() {
      return isAuthenticated() &&
        (getUserData().role == 'teacher' || 
          request.auth.token.email == "estherreyes012@gmail.com");
    }

    function isAdmin() {
      return isMIS() || isTeacher();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string &&
             data.role in ['student', 'teacher', 'mis'];
    }

    function isValidTeacher(data) {
      return data.keys().hasAll(['id', 'name', 'email']) &&
             data.id is string &&
             data.name is string &&
             data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['id', 'name', 'email']) &&
             data.id is string &&
             data.name is string &&
             data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string;
    }

    function isValidAcademicYear(data) {
      return data.keys().hasAll(['id', 'date']) &&
             data.id is number &&
             data.date is string;
    }

    function isValidSemester(data) {
      return data.keys().hasAll(['id', 'half']) &&
             data.id is number &&
             data.half is string;
    }

    function isValidInstitutionUser(data) {
      return data.keys().hasAll(['id', 'lastName', 'firstName', 'email', 'role']) &&
             data.id is number &&
             data.lastName is string &&
             data.firstName is string &&
             data.email is string &&
             data.role in ['Student', 'Teacher', 'MIS'];
    }

    function isValidClass(data) {
      return data.keys().hasAll(['id', 'academicYearId', 'semesterId', 'sectionId', 'userId']) &&
             data.id is number &&
             data.academicYearId is number &&
             data.semesterId is number &&
             data.sectionId is number &&
             data.userId is number;
    }

    function isValidClassUser(data) {
      return data.keys().hasAll(['classId', 'userId']) &&
             data.classId is number &&
             data.userId is number;
    }

    function isValidSection(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.id is number &&
             data.name is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isMIS() || isTeacher();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'student' || 
                     request.auth.token.email == "estherreyes012@gmail.com" ||
                     isMIS());
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isMIS();
      
      match /studyPlans/{planId} {
        allow read, write: if isOwner(userId) || isMIS();
      }
    }

    match /academicYears/{yearId} {
      allow read: if isAuthenticated();
      allow create, update: if isMIS() && isValidAcademicYear(request.resource.data);
      allow delete: if isMIS();
    }

    match /semesters/{semesterId} {
      allow read: if isAuthenticated();
      allow create, update: if isMIS() && isValidSemester(request.resource.data);
      allow delete: if isMIS();
    }

    match /institutionUsers/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isMIS() && isValidInstitutionUser(request.resource.data);
      allow delete: if isMIS();
    }

    match /sections/{sectionId} {
      allow read: if isAuthenticated();
      allow create, update: if isMIS() && isValidSection(request.resource.data);
      allow delete: if isMIS();
    }

    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create, update: if isMIS() && isValidClass(request.resource.data);
      allow delete: if isMIS();
    }

    match /classUsers/{linkId} {
      allow read: if isAuthenticated();
      allow create, update: if isMIS() && isValidClassUser(request.resource.data);
      allow delete: if isMIS();
    }
  }
}
